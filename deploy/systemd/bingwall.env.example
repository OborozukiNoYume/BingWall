BINGWALL_APP_ENV=production
BINGWALL_APP_HOST=127.0.0.1
BINGWALL_APP_PORT=8000
BINGWALL_APP_BASE_URL=http://127.0.0.1
BINGWALL_SITE_NAME=BingWall
BINGWALL_SITE_DESCRIPTION=Bing 壁纸图片服务
BINGWALL_DATABASE_PATH=/var/lib/bingwall/data/bingwall.sqlite3
BINGWALL_STORAGE_TMP_DIR=/var/lib/bingwall/images/tmp
BINGWALL_STORAGE_PUBLIC_DIR=/var/lib/bingwall/images/public
BINGWALL_STORAGE_FAILED_DIR=/var/lib/bingwall/images/failed
# Optional: set only when resources use storage_backend=oss.
# BINGWALL_STORAGE_OSS_PUBLIC_BASE_URL=https://cdn.example.com/bingwall
BINGWALL_BACKUP_DIR=/var/backups/bingwall
BINGWALL_COLLECT_BING_ENABLED=true
BINGWALL_COLLECT_BING_DEFAULT_MARKET=en-US
BINGWALL_COLLECT_BING_TIMEOUT_SECONDS=10
BINGWALL_COLLECT_BING_MAX_DOWNLOAD_RETRIES=3
BINGWALL_COLLECT_AUTO_PUBLISH_ENABLED=true
BINGWALL_SECURITY_SESSION_SECRET=replace-with-a-32-byte-secret-value
BINGWALL_SECURITY_SESSION_TTL_HOURS=12
# Optional: create an enabled super_admin during db-migrate when admin_users is empty.
# BINGWALL_SECURITY_BOOTSTRAP_ADMIN_USERNAME=admin
# BINGWALL_SECURITY_BOOTSTRAP_ADMIN_PASSWORD=replace-with-a-strong-admin-password
BINGWALL_LOG_LEVEL=INFO
