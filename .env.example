BINGWALL_APP_ENV=development
BINGWALL_APP_HOST=127.0.0.1
BINGWALL_APP_PORT=8000
BINGWALL_APP_BASE_URL=http://127.0.0.1:8000
BINGWALL_DATABASE_PATH=./var/data/bingwall.sqlite3
BINGWALL_STORAGE_TMP_DIR=./var/images/tmp
BINGWALL_STORAGE_PUBLIC_DIR=./var/images/public
BINGWALL_STORAGE_FAILED_DIR=./var/images/failed
BINGWALL_BACKUP_DIR=./var/backups
BINGWALL_SECURITY_SESSION_SECRET=replace-with-a-32-byte-secret-value
BINGWALL_SECURITY_SESSION_TTL_HOURS=12
BINGWALL_LOG_LEVEL=INFO
